<UserControl
    x:Class="BMATM.Views.LoginView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border
            Grid.Row="1"
            MaxWidth="500"
            Margin="20"
            Background="White"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="1"
            CornerRadius="10">
            <Border.Effect>
                <DropShadowEffect
                    BlurRadius="20"
                    Direction="270"
                    Opacity="0.2"
                    ShadowDepth="5" />
            </Border.Effect>

            <StackPanel Margin="40,30">
                <!--  Title  -->
                <TextBlock
                    Margin="0,0,0,30"
                    HorizontalAlignment="Center"
                    FontSize="24"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryColor}"
                    Text="{DynamicResource LoginTitle}" />

                <!--  Username Field  -->
                <TextBlock Style="{DynamicResource LabelStyle}" Text="{DynamicResource DomainUsername}" />

                <TextBox
                    Margin="0,0,0,20"
                    Style="{DynamicResource InputTextBoxStyle}"
                    Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}" />

                <CheckBox
                    Margin="0,0,0,20"
                    Content="{DynamicResource RememberMe}"
                    IsChecked="{Binding RememberMe}" />

                <!--  Password Field  -->
                <TextBlock Style="{DynamicResource LabelStyle}" Text="{DynamicResource Password}" />
                <PasswordBox
                    x:Name="PasswordBox"
                    Margin="0,0,0,20"
                    Padding="10,8"
                    FontSize="14"
                    PasswordChanged="PasswordBox_PasswordChanged"
                    Style="{DynamicResource InputPasswordBoxStyle}" />

                <!--  Error Message  -->
                <TextBlock
                    Margin="0,0,0,20"
                    Style="{DynamicResource ErrorTextStyle}"
                    Text="{Binding ErrorMessage}"
                    TextWrapping="Wrap"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}" />

                <!--  Login Button  -->
                <Button
                    Height="45"
                    Margin="0,10,0,0"
                    Command="{Binding LoginCommand}"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{DynamicResource PrimaryButtonStyle}">
                    <Grid>
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Text="{DynamicResource LoginButton}"
                            Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}" />
                        <ProgressBar
                            Width="20"
                            Height="20"
                            IsIndeterminate="True"
                            Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    </Grid>
                </Button>

                <!--  Demo Credentials  -->
                <Border
                    Margin="0,20,0,0"
                    Padding="10"
                    Background="#F8F9FA"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="5">
                    <StackPanel>
                        <TextBlock
                            FontSize="12"
                            FontWeight="SemiBold"
                            Text="Demo Credentials:" />
                        <TextBlock FontSize="11" Text="Username: admin, supervisor, operator" />
                        <TextBlock FontSize="11" Text="Password: password" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>