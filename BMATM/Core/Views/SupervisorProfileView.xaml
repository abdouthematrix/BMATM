<UserControl
    x:Class="BMATM.Views.SupervisorProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!--  Company Logo Background  -->
        <Grid.Background>
            <ImageBrush
                AlignmentY="Center"
                ImageSource="/Resources/Images/CompanyLogo.png"
                Opacity="0.75"
                Stretch="Uniform"
                TileMode="Tile"
                Viewport="0,0,100,100"
                ViewportUnits="Absolute" />
        </Grid.Background>

        <!--  Overlay for better readability  -->
        <Grid Background="#F8F9FA" Opacity="0.75" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  Header  -->
            <Border
                Grid.Row="0"
                Padding="20"
                Background="{DynamicResource PrimaryColor}"
                BorderBrush="{DynamicResource BorderColor}"
                BorderThickness="0,0,0,1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        FontSize="24"
                        FontWeight="Bold"
                        Foreground="White"
                        Text="{DynamicResource SupervisorProfile}" />

                    <Button
                        Grid.Column="1"
                        Margin="0,0,10,0"
                        Background="Transparent"
                        BorderBrush="White"
                        Command="{Binding RefreshCommand}"
                        Content="{DynamicResource Refresh}"
                        Foreground="White"
                        Style="{DynamicResource SecondaryButtonStyle}" />

                    <Button
                        Grid.Column="2"
                        Background="Transparent"
                        BorderBrush="White"
                        Command="{Binding LogoutCommand}"
                        Content="{DynamicResource Logout}"
                        Foreground="White"
                        Style="{DynamicResource SecondaryButtonStyle}" />
                </Grid>
            </Border>

            <!--  Content  -->
            <ScrollViewer
                Grid.Row="1"
                Padding="20"
                VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="1500" HorizontalAlignment="Center">

                    <!--  Loading Indicator  -->
                    <Grid Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border
                            Padding="40"
                            Background="White"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1"
                            CornerRadius="8">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock
                                    Margin="0,0,0,10"
                                    HorizontalAlignment="Center"
                                    FontSize="16"
                                    Text="{DynamicResource Loading}" />
                                <ProgressBar
                                    Width="200"
                                    Height="4"
                                    Background="{DynamicResource BackgroundColor}"
                                    Foreground="{DynamicResource PrimaryColor}"
                                    IsIndeterminate="True" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!--  Profile Content  -->
                    <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">

                        <!--  Welcome Message  -->
                        <Border
                            Margin="0,0,0,20"
                            Padding="20"
                            Background="White"
                            BorderBrush="{DynamicResource PrimaryColor}"
                            BorderThickness="2"
                            CornerRadius="8">
                            <StackPanel>
                                <TextBlock
                                    HorizontalAlignment="Center"
                                    FontSize="18"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryColor}"
                                    Text="{DynamicResource Welcome}" />
                                <TextBlock
                                    Margin="0,5,0,0"
                                    HorizontalAlignment="Center"
                                    FontSize="22"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryColor}"
                                    Text="{Binding SupervisorProfile.User.DisplayName}" />
                            </StackPanel>
                        </Border>

                        <!--  Two Column Layout  -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="430" />
                                <ColumnDefinition Width="450" />
                            </Grid.ColumnDefinitions>

                            <!--  Left Column: User Information  -->
                            <StackPanel Grid.Column="0" Margin="0,0,20,0">
                                <!--  User Information Card  -->
                                <Border
                                    Margin="0,0,0,20"
                                    Padding="25"
                                    Background="White"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  Section Header  -->
                                        <TextBlock
                                            Grid.Row="0"
                                            Margin="0,0,0,20"
                                            FontSize="18"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource PrimaryColor}"
                                            Text="{DynamicResource UserInformation}" />

                                        <!--  User Details Grid  -->
                                        <Grid Grid.Row="1">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!--  Display Name  -->
                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="0"
                                                Margin="0,0,0,15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextColor}"
                                                Text="{DynamicResource DisplayName}" />
                                            <TextBlock
                                                Grid.Row="0"
                                                Grid.Column="1"
                                                Margin="0,0,0,15"
                                                FontSize="14"
                                                Text="{Binding SupervisorProfile.User.DisplayName}" />

                                            <!--  Username  -->
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="0"
                                                Margin="0,0,0,15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextColor}"
                                                Text="{DynamicResource Username}" />
                                            <TextBlock
                                                Grid.Row="1"
                                                Grid.Column="1"
                                                Margin="0,0,0,15"
                                                FontSize="14"
                                                Text="{Binding SupervisorProfile.User.Username}" />

                                            <!--  Email  -->
                                            <TextBlock
                                                Grid.Row="2"
                                                Grid.Column="0"
                                                Margin="0,0,0,15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextColor}"
                                                Text="{DynamicResource Email}" />
                                            <TextBlock
                                                Grid.Row="2"
                                                Grid.Column="1"
                                                Margin="0,0,0,15"
                                                FontSize="14"
                                                Text="{Binding SupervisorProfile.User.Email}" />

                                            <!--  Department  -->
                                            <TextBlock
                                                Grid.Row="3"
                                                Grid.Column="0"
                                                Margin="0,0,0,15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextColor}"
                                                Text="{DynamicResource Department}" />
                                            <TextBlock
                                                Grid.Row="3"
                                                Grid.Column="1"
                                                Margin="0,0,0,15"
                                                FontSize="14"
                                                Text="{Binding SupervisorProfile.User.Department}" />

                                            <!--  Branch Number  -->
                                            <TextBlock
                                                Grid.Row="4"
                                                Grid.Column="0"
                                                Margin="0,0,0,15"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextColor}"
                                                Text="{DynamicResource BranchNumber}" />
                                            <TextBlock
                                                Grid.Row="4"
                                                Grid.Column="1"
                                                Margin="0,0,0,15"
                                                FontSize="14"
                                                Text="{Binding SupervisorProfile.User.BranchNumber}" />

                                            <!--  Branch Name  -->
                                            <TextBlock
                                                Grid.Row="5"
                                                Grid.Column="0"
                                                FontWeight="SemiBold"
                                                Foreground="{DynamicResource TextColor}"
                                                Text="{DynamicResource BranchName}" />
                                            <TextBlock
                                                Grid.Row="5"
                                                Grid.Column="1"
                                                FontSize="14"
                                                Text="{Binding SupervisorProfile.User.BranchName}" />
                                        </Grid>
                                    </Grid>
                                </Border>
                                <!--  Last Login Info  -->
                                <Border
                                    Padding="15"
                                    Background="{DynamicResource BackgroundColor}"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            Margin="0,0,10,0"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource TextColor}"
                                            Text="{DynamicResource LastLogin}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            FontSize="14"
                                            Text="{Binding SupervisorProfile.User.LastLogin, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                                    </Grid>
                                </Border>
                            </StackPanel>

                            <!--  Right Column: ATM Collection  -->
                            <StackPanel Grid.Column="1">
                                <!--  ATM Collection Header  -->
                                <Border
                                    Margin="0,0,0,20"
                                    Padding="20"
                                    Background="White"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock
                                            Grid.Column="0"
                                            VerticalAlignment="Center"
                                            FontSize="20"
                                            FontWeight="SemiBold"
                                            Foreground="{DynamicResource PrimaryColor}"
                                            Text="{DynamicResource ATMCollection}" />

                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="14"
                                            Foreground="{DynamicResource TextColor}">
                                            <Run Text="{DynamicResource Total}" />
                                            <Run FontWeight="Bold" Text="{Binding ATMs.Count, Mode=OneWay}" />
                                            <Run Text="{DynamicResource ATMs}" />
                                        </TextBlock>
                                    </Grid>
                                </Border>

                                <!--  ATM Cards  -->
                                <Border
                                    Background="White"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="1"
                                    CornerRadius="8">

                                    <ScrollViewer MaxHeight="600" VerticalScrollBarVisibility="Auto">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition />
                                                <RowDefinition />
                                            </Grid.RowDefinitions>
                                            <!--  Empty State  -->
                                            <StackPanel
                                                Grid.Row="1"
                                                Margin="40"
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center">
                                                <TextBlock
                                                    Margin="0,0,0,20"
                                                    HorizontalAlignment="Center"
                                                    FontSize="16"
                                                    FontStyle="Italic"
                                                    Foreground="Gray"
                                                    Text="{DynamicResource NoATMsMessage}"
                                                    TextAlignment="Center"
                                                    TextWrapping="Wrap"
                                                    Visibility="{Binding ATMs.Count, Mode=OneWay, Converter={StaticResource CountToVisibilityConverter}}" />
                                                <Button
                                                    Padding="20,10"
                                                    Command="{Binding AddATMCommand}"
                                                    Content="{DynamicResource AddATM}"
                                                    Style="{DynamicResource PrimaryButtonStyle}" />
                                            </StackPanel>

                                            <!--  ATM List  -->
                                            <ItemsControl ItemsSource="{Binding ATMs}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border
                                                            Margin="15,10,15,10"
                                                            Background="#FAFAFA"
                                                            BorderBrush="{DynamicResource BorderColor}"
                                                            BorderThickness="1"
                                                            CornerRadius="6">
                                                            <Grid Margin="20,15">
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="80" />
                                                                    <ColumnDefinition Width="*" />
                                                                    <ColumnDefinition Width="Auto" />
                                                                </Grid.ColumnDefinitions>

                                                                <!--  ATM Icon  -->
                                                                <Image
                                                                    Grid.Column="0"
                                                                    Width="60"
                                                                    Height="60"
                                                                    Source="{Binding ATMType, Converter={StaticResource ATMTypeToImageConverter}}"
                                                                    Stretch="Uniform" />

                                                                <!--  ATM Details  -->
                                                                <StackPanel Grid.Column="1" Margin="15,0,0,0">
                                                                    <TextBlock
                                                                        FontSize="16"
                                                                        FontWeight="Bold"
                                                                        Text="{Binding ATMNumber}" />
                                                                    <TextBlock
                                                                        Margin="0,2,0,0"
                                                                        FontSize="13"
                                                                        Foreground="Gray"
                                                                        Text="{Binding ATMType, Converter={StaticResource ATMTypeToDisplayNameConverter}}" />
                                                                    <TextBlock
                                                                        Margin="0,2,0,0"
                                                                        FontSize="13"
                                                                        Text="{Binding Location}" />
                                                                    <TextBlock
                                                                        Margin="0,2,0,0"
                                                                        FontSize="13"
                                                                        Text="{Binding BranchName}" />
                                                                    <TextBlock
                                                                        Margin="0,5,0,0"
                                                                        FontSize="12"
                                                                        FontWeight="SemiBold"
                                                                        Foreground="{Binding IsActive, Converter={StaticResource BooleanToStatusColorConverter}}"
                                                                        Text="{Binding IsActive, Converter={StaticResource BooleanToStatusConverter}}" />
                                                                </StackPanel>

                                                                <!--  Action Buttons  -->
                                                                <StackPanel Grid.Column="2" Orientation="Horizontal">
                                                                    <Button
                                                                        Width="60"
                                                                        Height="50"
                                                                        Margin="0,0,5,0"
                                                                        Command="{Binding DataContext.EditATMCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="{DynamicResource Edit}"
                                                                        FontSize="11"
                                                                        Style="{DynamicResource SecondaryButtonStyle}" />
                                                                    <Button
                                                                        Width="50"
                                                                        Height="50"
                                                                        Command="{Binding DataContext.DeleteATMCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                        CommandParameter="{Binding}"
                                                                        Content="X"
                                                                        FontSize="11"
                                                                        Style="{DynamicResource DangerButtonStyle}" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </ScrollViewer>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>