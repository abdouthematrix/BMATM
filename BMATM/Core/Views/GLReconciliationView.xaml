<!--  Filename: Views/GLReconciliationView.xaml  -->
<UserControl
    x:Class="BMATM.Views.GLReconciliationView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="800"
    d:DesignWidth="1000"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Padding="20"
            Background="{DynamicResource PrimaryColor}"
            BorderBrush="{DynamicResource BorderColor}"
            BorderThickness="0,0,0,1">
            <TextBlock
                HorizontalAlignment="Center"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"
                Text="{DynamicResource GLReconciliation}" />
        </Border>

        <!--  Content  -->
        <ScrollViewer
            Grid.Row="1"
            Padding="20"
            VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="1200" HorizontalAlignment="Center">
                <!--  Main Reconciliation Card  -->
                <Border
                    Margin="0,0,0,20"
                    Padding="25"
                    Background="White"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Table Header  -->
                        <Border
                            Grid.Row="0"
                            Background="{DynamicResource BackgroundColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1,1,1,0"
                            CornerRadius="4,4,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>

                                <Border
                                    Grid.Column="0"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="0,0,1,0">
                                    <TextBlock Style="{StaticResource HeaderCellStyle}" Text="{DynamicResource AdjustmentLabel}" />
                                </Border>

                                <Border
                                    Grid.Column="1"
                                    BorderBrush="{DynamicResource BorderColor}"
                                    BorderThickness="0,0,1,0">
                                    <TextBlock Style="{StaticResource HeaderCellStyle}" Text="{DynamicResource Amount}" />
                                </Border>

                                <Border Grid.Column="2">
                                    <TextBlock Style="{StaticResource HeaderCellStyle}" Text="+/-" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  Remaining Cash Row  -->
                        <Border
                            Grid.Row="1"
                            Background="#FAFAFA"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1,0,1,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource DataRowBorderStyle}">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Style="{StaticResource DataCellStyle}"
                                        Text="{DynamicResource RemainingCash}" />
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource DataRowBorderStyle}">
                                    <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding GLReconciliation.RemainingCash, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" />
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource LastColumnBorderStyle}">
                                    <TextBlock Style="{StaticResource OperationCellStyle}" Text="" />
                                </Border>
                            </Grid>
                        </Border>

                        <!--  GL Adjustments Rows  -->
                        <ItemsControl Grid.Row="2" ItemsSource="{Binding GLReconciliation.GLAdjustments}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border
                                        Background="White"
                                        BorderBrush="{DynamicResource BorderColor}"
                                        BorderThickness="1,0,1,1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="200" />
                                                <ColumnDefinition Width="50" />
                                            </Grid.ColumnDefinitions>

                                            <!--  Adjustment Label  -->
                                            <Border Grid.Column="0" Style="{StaticResource DataRowBorderStyle}">
                                                <TextBlock
                                                    HorizontalAlignment="Left"
                                                    Style="{StaticResource DataCellStyle}"
                                                    Text="{Binding AdjustmentLabel}"
                                                    TextTrimming="CharacterEllipsis"
                                                    ToolTip="{Binding AdjustmentLabel}" />
                                            </Border>

                                            <!--  Amount  -->
                                            <Border Grid.Column="1" Style="{StaticResource DataRowBorderStyle}">
                                                <TextBox Style="{StaticResource InputTextBoxStyle}" Text="{Binding Amount, StringFormat=N2, UpdateSourceTrigger=PropertyChanged}" />
                                            </Border>

                                            <!--  Operation  -->
                                            <Border Grid.Column="2" Style="{StaticResource LastColumnBorderStyle}">
                                                <TextBlock Style="{StaticResource OperationCellStyle}" Text="{Binding Operation}" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!--  Summary Row  -->
                        <Border
                            Grid.Row="3"
                            Background="{DynamicResource BackgroundColor}"
                            BorderBrush="{DynamicResource BorderColor}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="50" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Style="{StaticResource DataRowBorderStyle}">
                                    <TextBlock Style="{StaticResource HeaderCellStyle}" Text="{DynamicResource GLBalance}" />
                                </Border>

                                <Border Grid.Column="1" Style="{StaticResource DataRowBorderStyle}">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="{DynamicResource PrimaryColor}"
                                        Style="{StaticResource AmountCellStyle}"
                                        Text="{Binding GLReconciliation.GLBalance, StringFormat=N2}" />
                                </Border>

                                <Border Grid.Column="2" Style="{StaticResource LastColumnBorderStyle}">
                                    <TextBlock Style="{StaticResource OperationCellStyle}" Text="=" />
                                </Border>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>