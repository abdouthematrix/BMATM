<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <!--  The name of this ResourceDictionary. Should not be localized.  -->
    <sys:String x:Key="ResourceDictionaryName">Strings.ar</sys:String>
    <!--  Application Title  -->
    <sys:String x:Key="AppTitle">BMATM - نظام إدارة أجهزة الصراف الآلي</sys:String>

    <!--  Flow Direction  -->
    <FlowDirection x:Key="FlowDirection">RightToLeft</FlowDirection>

    <!--  Welcome Messages  -->
    <sys:String x:Key="WelcomeMessage">مرحباً بك في نظام إدارة أجهزة الصراف الآلي</sys:String>

    <!--  Login Screen  -->
    <sys:String x:Key="LoginTitle">تسجيل الدخول</sys:String>
    <sys:String x:Key="Username">اسم المستخدم</sys:String>
    <sys:String x:Key="Password">كلمة المرور</sys:String>
    <sys:String x:Key="LoginButton">تسجيل الدخول</sys:String>
    <sys:String x:Key="LoginError">اسم المستخدم أو كلمة المرور غير صحيحة</sys:String>
    <sys:String x:Key="DomainUsername">اسم المستخدم</sys:String>
    <sys:String x:Key="RememberMe">تذكرني</sys:String>

    <!--  Supervisor Profile Screen  -->
    <sys:String x:Key="Name">الاسم</sys:String>
    <sys:String x:Key="SupervisorProfile">ملف المشرف</sys:String>
    <sys:String x:Key="Welcome">أهلاً وسهلاً</sys:String>
    <sys:String x:Key="UserInformation">معلومات المستخدم</sys:String>
    <sys:String x:Key="FullName">الاسم الكامل</sys:String>
    <sys:String x:Key="BranchNumber">رقم الفرع</sys:String>
    <sys:String x:Key="BranchName">اسم الفرع</sys:String>
    <sys:String x:Key="ATMCollection">مجموعة أجهزة الصراف الآلي</sys:String>
    <sys:String x:Key="ATMCount">عدد أجهزة الصراف الآلي</sys:String>
    <sys:String x:Key="AddATM">إضافة صراف آلي</sys:String>
    <sys:String x:Key="NoATMsMessage">لم يتم تكوين أي أجهزة صراف آلي بعد. انقر على 'إضافة صراف آلي' للبدء.</sys:String>
    <sys:String x:Key="LastLogin">آخر تسجيل دخول</sys:String>
    <sys:String x:Key="Logout">تسجيل الخروج</sys:String>
    <sys:String x:Key="Refresh">تحديث</sys:String>
    <sys:String x:Key="Loading">جاري التحميل...</sys:String>

    <!--  Common  -->
    <sys:String x:Key="OK">موافق</sys:String>
    <sys:String x:Key="Close">إغلاق</sys:String>
    <sys:String x:Key="Back">رجوع</sys:String>
    <sys:String x:Key="Next">التالي</sys:String>
    <sys:String x:Key="Previous">السابق</sys:String>
    <sys:String x:Key="Search">بحث</sys:String>
    <sys:String x:Key="Clear">مسح</sys:String>
    <sys:String x:Key="Delete">حذف</sys:String>
    <sys:String x:Key="Edit">تعديل</sys:String>
    <sys:String x:Key="View">عرض</sys:String>

    <!--  Validation Messages  -->
    <sys:String x:Key="RequiredField">هذا الحقل مطلوب</sys:String>
    <sys:String x:Key="InvalidFormat">صيغة غير صحيحة</sys:String>
    <sys:String x:Key="InvalidNumber">رقم غير صحيح</sys:String>

</ResourceDictionary>