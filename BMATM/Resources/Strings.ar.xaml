<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  The name of this ResourceDictionary. Should not be localized.  -->
    <sys:String x:Key="ResourceDictionaryName">Strings.ar</sys:String>

    <!--  Application Title  -->
    <sys:String x:Key="AppTitle">BMATM - نظام إدارة الات الصرف الذاتي</sys:String>

    <!--  Flow Direction  -->
    <FlowDirection x:Key="FlowDirection">RightToLeft</FlowDirection>

    <!--  Welcome Messages  -->
    <sys:String x:Key="WelcomeMessage">مرحباً بك في نظام إدارة الات الصرف الذاتي</sys:String>

    <!--  Login Screen  -->
    <sys:String x:Key="LoginTitle">تسجيل الدخول</sys:String>
    <sys:String x:Key="Username">اسم المستخدم</sys:String>
    <sys:String x:Key="Password">كلمة المرور</sys:String>
    <sys:String x:Key="LoginButton">تسجيل الدخول</sys:String>
    <sys:String x:Key="DomainUsername">اسم المستخدم للنطاق</sys:String>
    <sys:String x:Key="RememberMe">تذكرني</sys:String>

    <!--  Authentication Error Messages  -->
    <sys:String x:Key="AuthUsernameRequired">اسم المستخدم مطلوب</sys:String>
    <sys:String x:Key="AuthPasswordRequired">كلمة المرور مطلوبة</sys:String>
    <sys:String x:Key="AuthAccountLocked">تم قفل الحساب بسبب كثرة المحاولات الفاشلة. حاول مرة أخرى خلال {0} دقيقة.</sys:String>
    <sys:String x:Key="AuthInvalidCredentials">اسم المستخدم أو كلمة المرور غير صحيحة</sys:String>
    <sys:String x:Key="AuthUserNotFound">اسم المستخدم أو كلمة المرور غير صحيحة</sys:String>
    <sys:String x:Key="AuthUserInactive">حساب المستخدم معطل</sys:String>
    <sys:String x:Key="AuthDatabaseError">حدث خطأ أثناء المصادقة</sys:String>
    <sys:String x:Key="AuthAttemptsRemaining">{0} محاولة متبقية.</sys:String>

    <!--  Supervisor Profile Screen  -->
    <sys:String x:Key="SupervisorProfile">ملف المشرف</sys:String>
    <sys:String x:Key="UserInformation">معلومات المستخدم</sys:String>
    <sys:String x:Key="DisplayName">الاسم الكامل</sys:String>
    <sys:String x:Key="Email">البريد الإلكتروني</sys:String>
    <sys:String x:Key="Department">القسم</sys:String>
    <sys:String x:Key="BranchNumber">رقم الفرع</sys:String>
    <sys:String x:Key="BranchName">اسم الفرع</sys:String>
    <sys:String x:Key="ATMCollection">مجموعة الات الصرف الذاتي</sys:String>
    <sys:String x:Key="AddATM">إضافة الة صرف ذاتي</sys:String>
    <sys:String x:Key="NoATMsMessage">لم يتم تكوين الات صرف ذاتي بعد. انقر على 'إضافة الة صرف ذاتي' للبدء.</sys:String>
    <sys:String x:Key="LastLogin">آخر تسجيل دخول</sys:String>
    <sys:String x:Key="Logout">تسجيل الخروج</sys:String>
    <sys:String x:Key="Refresh">تحديث</sys:String>
    <sys:String x:Key="Loading">جاري التحميل...</sys:String>

    <!--  ATM Collection Display  -->
    <sys:String x:Key="Total">المجموع</sys:String>
    <sys:String x:Key="ATMs">الات صرف ذاتي</sys:String>
    <sys:String x:Key="ATMTypeLabel">النوع:</sys:String>
    <sys:String x:Key="StatusLabel">الحالة:</sys:String>

    <!--  Group Headers  -->
    <sys:String x:Key="BasicInformationGroupHeader">المعلومات الأساسية</sys:String>
    <sys:String x:Key="CassetteInformationGroupHeader">معلومات الادراج</sys:String>

    <!--  Basic Information Labels  -->
    <sys:String x:Key="ATMNumberLabel">رقم الة الصرف الذاتي:</sys:String>
    <sys:String x:Key="GLAccountLabel">حساب الأستاذ العام:</sys:String>
    <sys:String x:Key="BranchCodeLabel">رقم الفرع:</sys:String>
    <sys:String x:Key="BranchNameLabel">اسم الفرع:</sys:String>

    <!--  Location Information Labels  -->
    <sys:String x:Key="ActiveStatusText">نشط</sys:String>

    <!--  Cassette Information Labels  -->
    <sys:String x:Key="CassetteLabel">درج</sys:String>
    <sys:String x:Key="DenominationLabel">الفئة</sys:String>
    <sys:String x:Key="Cassette1Label">1</sys:String>
    <sys:String x:Key="Cassette2Label">2</sys:String>
    <sys:String x:Key="Cassette3Label">3</sys:String>
    <sys:String x:Key="Cassette4Label">4</sys:String>

    <!--  Button Labels  -->
    <sys:String x:Key="CancelButtonText">إلغاء</sys:String>

    <!--  GL Reconciliation Strings  -->
    <sys:String x:Key="GLReconciliation">معادلة الأستاذ العام</sys:String>
    <sys:String x:Key="RemainingCash">النقدية المتبقية</sys:String>
    <sys:String x:Key="GLAdjustments">تسويات الأستاذ العام</sys:String>
    <sys:String x:Key="GLBalance">رصيد الأستاذ العام</sys:String>
    <sys:String x:Key="Amount">المبلغ</sys:String>
    <sys:String x:Key="AdjustmentLabel">التسوية</sys:String>

    <!--  Formula Display  -->
    <sys:String x:Key="Formula">المعادلة: رصيد دفتر الأستاذ العام = النقدية المتبقية ± تسويات دفتر الأستاذ العام</sys:String>

</ResourceDictionary>