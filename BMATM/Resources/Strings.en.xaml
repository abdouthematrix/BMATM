    <sys:String x:Key="ActiveStatus">Active</sys:String>
    <sys:String x:Key="InactiveStatus">Inactive</sys:String>
    <sys:String x:Key="MaintenanceStatus">Maintenance</sys:String>
    <sys:String x:Key="OutOfOrderStatus">Out of Order</sys:String>

    <!--  ATM Types  -->
    <sys:String x:Key="ATMTypeStandard">Standard ATM</sys:String>
    <sys:String x:Key="ATMTypeDeposit">Deposit ATM</sys:String>
    <sys:String x:Key="ATMTypeMobile">Mobile ATM</sys:String>
    <sys:String x:Key="ATMTypeMultiFunction">Multi-Function ATM</sys:String>

    <!--  Add/Edit ATM Form  -->
    <sys:String x:Key="AddATMTitle">Add New ATM</sys:String>
    <sys:String x:Key="EditATMTitle">Edit ATM</sys:String>

