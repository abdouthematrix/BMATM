<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  The name of this ResourceDictionary. Should not be localized.  -->
    <sys:String x:Key="ResourceDictionaryName">Strings.en</sys:String>

    <!--  Application Title  -->
    <sys:String x:Key="AppTitle">BMATM - Bank ATM Management</sys:String>

    <!--  Flow Direction  -->
    <FlowDirection x:Key="FlowDirection">LeftToRight</FlowDirection>

    <!--  Welcome Messages  -->
    <sys:String x:Key="WelcomeMessage">Welcome to Bank ATM Management System</sys:String>

    <!--  Login Screen  -->
    <sys:String x:Key="LoginTitle">Login</sys:String>
    <sys:String x:Key="Username">Username</sys:String>
    <sys:String x:Key="Password">Password</sys:String>
    <sys:String x:Key="LoginButton">Login</sys:String>
    <sys:String x:Key="LoginError">Invalid username or password</sys:String>
    <sys:String x:Key="DomainUsername">Domain Username</sys:String>
    <sys:String x:Key="RememberMe">Remember me</sys:String>

    <!--  Authentication Error Messages  -->
    <sys:String x:Key="AuthUsernameRequired">Username is required</sys:String>
    <sys:String x:Key="AuthPasswordRequired">Password is required</sys:String>
    <sys:String x:Key="AuthAccountLocked">Account is locked due to too many failed attempts. Try again in {0} minutes.</sys:String>
    <sys:String x:Key="AuthInvalidCredentials">Invalid username or password</sys:String>
    <sys:String x:Key="AuthUserNotFound">Invalid username or password</sys:String>
    <sys:String x:Key="AuthUserInactive">User account is disabled</sys:String>
    <sys:String x:Key="AuthDatabaseError">An error occurred during authentication</sys:String>
    <sys:String x:Key="AuthAttemptsRemaining">{0} attempts remaining.</sys:String>

    <!--  Supervisor Profile Screen  -->
    <sys:String x:Key="Name">Name</sys:String>
    <sys:String x:Key="SupervisorProfile">Supervisor Profile</sys:String>
    <sys:String x:Key="Welcome">Welcome</sys:String>
    <sys:String x:Key="UserInformation">User Information</sys:String>
    <sys:String x:Key="DisplayName">Full Name</sys:String>
    <sys:String x:Key="Email">Email Address</sys:String>
    <sys:String x:Key="Department">Department</sys:String>
    <sys:String x:Key="BranchNumber">Branch Number</sys:String>
    <sys:String x:Key="BranchName">Branch Name</sys:String>
    <sys:String x:Key="ATMCollection">ATM Collection</sys:String>
    <sys:String x:Key="ATMCount">ATM Count</sys:String>
    <sys:String x:Key="AddATM">Add ATM</sys:String>
    <sys:String x:Key="NoATMsMessage">No ATMs configured yet. Click 'Add ATM' to get started.</sys:String>
    <sys:String x:Key="LastLogin">Last Login</sys:String>
    <sys:String x:Key="Logout">Logout</sys:String>
    <sys:String x:Key="Refresh">Refresh</sys:String>
    <sys:String x:Key="Loading">Loading...</sys:String>

    <!--  ATM Collection View  -->
    <!--  ATM Summary Section  -->
    <sys:String x:Key="ATMSummary">ATM Summary</sys:String>

    <!--  ATM Collection Display  -->
    <sys:String x:Key="Total">Total</sys:String>
    <sys:String x:Key="ATMs">ATMs</sys:String>
    <sys:String x:Key="AddFirstATM">Add First ATM</sys:String>
    <sys:String x:Key="ATMCollectionTitle">ATM Collection</sys:String>
    <sys:String x:Key="RefreshButtonText">Refresh</sys:String>
    <sys:String x:Key="AddATMButtonText">Add ATM</sys:String>
    <sys:String x:Key="LoadingText">Loading ATMs...</sys:String>
    <sys:String x:Key="ATMTypeLabel">Type:</sys:String>
    <sys:String x:Key="LocationLabel">Location:</sys:String>
    <sys:String x:Key="StatusLabel">Status:</sys:String>
    <sys:String x:Key="EditButtonText">Edit</sys:String>
    <sys:String x:Key="DeleteButtonText">Delete</sys:String>
    <sys:String x:Key="NoATMsFoundText">No ATMs found</sys:String>
    <sys:String x:Key="AddFirstATMButtonText">Add First ATM</sys:String>
    <sys:String x:Key="TotalATMsText">Total ATMs:</sys:String>

