<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!--  The name of this ResourceDictionary. Should not be localized.  -->
    <sys:String x:Key="ResourceDictionaryName">Strings.en</sys:String>

    <!--  Application Title  -->
    <sys:String x:Key="AppTitle">BMATM - Bank ATM Management</sys:String>

    <!--  Flow Direction  -->
    <FlowDirection x:Key="FlowDirection">LeftToRight</FlowDirection>

    <!--  Welcome Messages  -->
    <sys:String x:Key="WelcomeMessage">Welcome to Bank ATM Management System</sys:String>

    <!--  Login Screen  -->
    <sys:String x:Key="LoginTitle">Login</sys:String>
    <sys:String x:Key="Username">Username</sys:String>
    <sys:String x:Key="Password">Password</sys:String>
    <sys:String x:Key="LoginButton">Login</sys:String>
    <sys:String x:Key="LoginError">Invalid username or password</sys:String>
    <sys:String x:Key="DomainUsername">Domain Username</sys:String>
    <sys:String x:Key="RememberMe">Remember me</sys:String>

    <!--  Supervisor Profile  -->
    <sys:String x:Key="SupervisorProfile">Supervisor Profile</sys:String>
    <sys:String x:Key="Name">Name</sys:String>
    <sys:String x:Key="BranchNumber">Branch Number</sys:String>
    <sys:String x:Key="BranchName">Branch Name</sys:String>
    <sys:String x:Key="ATMCollection">ATM Collection</sys:String>
    <sys:String x:Key="ATMCount">ATM Count</sys:String>

    <!--  ATM Management  -->
    <sys:String x:Key="AddATM">Add ATM</sys:String>
    <sys:String x:Key="ATMType">ATM Type</sys:String>
    <sys:String x:Key="ATMName">ATM Name</sys:String>
    <sys:String x:Key="ATMNumber">ATM Number</sys:String>
    <sys:String x:Key="GLNumber">GL Number</sys:String>
    <sys:String x:Key="NumberOfCassettes">Number of Cassettes</sys:String>
    <sys:String x:Key="DenominationType">Denomination Type</sys:String>
    <sys:String x:Key="Save">Save</sys:String>
    <sys:String x:Key="Cancel">Cancel</sys:String>

    <!--  Common  -->
    <sys:String x:Key="OK">OK</sys:String>
    <sys:String x:Key="Close">Close</sys:String>
    <sys:String x:Key="Back">Back</sys:String>
    <sys:String x:Key="Next">Next</sys:String>
    <sys:String x:Key="Previous">Previous</sys:String>
    <sys:String x:Key="Search">Search</sys:String>
    <sys:String x:Key="Clear">Clear</sys:String>
    <sys:String x:Key="Delete">Delete</sys:String>
    <sys:String x:Key="Edit">Edit</sys:String>
    <sys:String x:Key="View">View</sys:String>

    <!--  Validation Messages  -->
    <sys:String x:Key="RequiredField">This field is required</sys:String>
    <sys:String x:Key="InvalidFormat">Invalid format</sys:String>
    <sys:String x:Key="InvalidNumber">Invalid number</sys:String>

</ResourceDictionary>