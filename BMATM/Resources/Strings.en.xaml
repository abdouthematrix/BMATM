    <sys:String x:Key="ATMNumberLabel">ATM Number:</sys:String>
    <sys:String x:Key="GLAccountLabel">GL Account:</sys:String>
    <sys:String x:Key="BranchCodeLabel">Branch Code:</sys:String>
    <sys:String x:Key="BranchNameLabel">Branch Name:</sys:String>

    <!--  Location Information Labels  -->
    <sys:String x:Key="IPAddressLabel">IP Address:</sys:String>
    <sys:String x:Key="ActiveStatusText">Active</sys:String>

    <!--  Dates Information Labels  -->
    <sys:String x:Key="InstallationDateLabel">Installation Date:</sys:String>
    <sys:String x:Key="LastMaintenanceDateLabel">Last Maintenance Date:</sys:String>

    <!--  Cassette Information Labels  -->
    <sys:String x:Key="CassetteLabel">Cassette</sys:String>
    <sys:String x:Key="DenominationLabel">Denomination</sys:String>
    <sys:String x:Key="BalanceLabel">Balance</sys:String>
    <sys:String x:Key="Cassette1Label">1</sys:String>
    <sys:String x:Key="Cassette2Label">2</sys:String>
    <sys:String x:Key="Cassette3Label">3</sys:String>
    <sys:String x:Key="Cassette4Label">4</sys:String>

    <!--  Button Labels  -->
    <sys:String x:Key="CancelButtonText">Cancel</sys:String>
    <sys:String x:Key="SaveButtonText">Save</sys:String>
    <sys:String x:Key="SavingText">Saving...</sys:String>

    <!--  Common  -->
    <sys:String x:Key="OK">OK</sys:String>
    <sys:String x:Key="Close">Close</sys:String>
    <sys:String x:Key="Back">Back</sys:String>
    <sys:String x:Key="Next">Next</sys:String>
    <sys:String x:Key="Previous">Previous</sys:String>
    <sys:String x:Key="Search">Search</sys:String>
    <sys:String x:Key="Clear">Clear</sys:String>
    <sys:String x:Key="Delete">Delete</sys:String>
    <sys:String x:Key="Edit">Edit</sys:String>
    <sys:String x:Key="View">View</sys:String>
    <sys:String x:Key="Save">Save</sys:String>
    <sys:String x:Key="Cancel">Cancel</sys:String>
    <sys:String x:Key="Yes">Yes</sys:String>
    <sys:String x:Key="No">No</sys:String>

    <!--  Validation Messages  -->
    <sys:String x:Key="RequiredField">This field is required</sys:String>
    <sys:String x:Key="InvalidFormat">Invalid format</sys:String>
    <sys:String x:Key="InvalidNumber">Invalid number</sys:String>

    <!--  Confirmation Messages  -->
    <sys:String x:Key="ConfirmDelete">Are you sure you want to delete this ATM?</sys:String>
    <sys:String x:Key="ConfirmDeleteTitle">Confirm Delete</sys:String>
    <sys:String x:Key="OperationSuccessful">Operation completed successfully</sys:String>
    <sys:String x:Key="OperationFailed">Operation failed. Please try again.</sys:String>

</ResourceDictionary>