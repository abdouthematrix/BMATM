    <sys:String x:Key="BasicInformationGroupHeader">Basic Information</sys:String>
    <sys:String x:Key="LocationInformationGroupHeader">Location Information</sys:String>
    <sys:String x:Key="DatesInformationGroupHeader">Dates Information</sys:String>
    <sys:String x:Key="CassetteInformationGroupHeader">Cassette Information</sys:String>
    <sys:String x:Key="NotesGroupHeader">Notes</sys:String>

