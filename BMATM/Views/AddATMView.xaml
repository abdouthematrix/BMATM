<!--  Filename: Views/AddATMView.xaml  -->
<UserControl
    x:Class="BMATM.Views.AddATMView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="700"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid Grid.Row="0" Background="{StaticResource PrimaryBrush}">
            <TextBlock
                Margin="20,15"
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"
                Text="{Binding IsEditMode, Converter={StaticResource BooleanToAddEditTitleConverter}}" />
        </Grid>

        <!--  Form Content  -->
        <ScrollViewer
            Grid.Row="1"
            Margin="20"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <Grid MaxWidth="800">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!--  Left Column  -->
                <StackPanel Grid.Column="0">
                    <!--  Basic Information  -->
                    <GroupBox
                        Margin="0,0,0,20"
                        Header="{DynamicResource BasicInformationGroupHeader}"
                        Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource ATMNumberLabel}" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                IsEnabled="{Binding IsEditMode, Converter={StaticResource InverseBooleanConverter}}"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding ATMNumber, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource ATMTypeLabel}" />
                            <ComboBox
                                Grid.Row="1"
                                Grid.Column="1"
                                ItemsSource="{Binding ATMTypes}"
                                SelectedItem="{Binding SelectedATMType}"
                                Style="{StaticResource ComboBoxStyle}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource GLAccountLabel}" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding GLAccount, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource BranchCodeLabel}" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="1"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding BranchCode, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource BranchNameLabel}" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="1"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding BranchName, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </GroupBox>

                    <!--  Location Information  -->
                    <GroupBox
                        Margin="0,0,0,20"
                        Header="{DynamicResource LocationInformationGroupHeader}"
                        Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource LocationLabel}" />
                            <TextBox
                                Grid.Row="0"
                                Grid.Column="1"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding Location, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource IPAddressLabel}" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="1"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding IPAddress, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource StatusLabel}" />
                            <CheckBox
                                Grid.Row="2"
                                Grid.Column="1"
                                Content="{DynamicResource ActiveStatusText}"
                                IsChecked="{Binding IsActive}"
                                Style="{StaticResource CheckBoxStyle}" />
                        </Grid>
                    </GroupBox>

                    <!--  Dates Information  -->
                    <GroupBox Header="{DynamicResource DatesInformationGroupHeader}" Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource InstallationDateLabel}" />
                            <DatePicker
                                Grid.Row="0"
                                Grid.Column="1"
                                SelectedDate="{Binding InstallationDate}"
                                Style="{StaticResource DatePickerStyle}" />

                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource LastMaintenanceDateLabel}" />
                            <DatePicker
                                Grid.Row="1"
                                Grid.Column="1"
                                SelectedDate="{Binding LastMaintenanceDate}"
                                Style="{StaticResource DatePickerStyle}" />
                        </Grid>
                    </GroupBox>
                </StackPanel>

                <!--  Right Column  -->
                <StackPanel Grid.Column="2">
                    <!--  Cassette Information  -->
                    <GroupBox
                        Margin="0,0,0,20"
                        Header="{DynamicResource CassetteInformationGroupHeader}"
                        Style="{StaticResource GroupBoxStyle}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!--  Headers  -->
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource CassetteLabel}" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="1"
                                HorizontalAlignment="Center"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource DenominationLabel}" />
                            <TextBlock
                                Grid.Row="0"
                                Grid.Column="2"
                                HorizontalAlignment="Center"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource BalanceLabel}" />

                            <!--  Cassette 1  -->
                            <TextBlock
                                Grid.Row="1"
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource Cassette1Label}" />
                            <ComboBox
                                Grid.Row="1"
                                Grid.Column="1"
                                ItemsSource="{Binding CassetteDenominations}"
                                SelectedItem="{Binding Cassette1Denomination}"
                                Style="{StaticResource ComboBoxStyle}" />
                            <TextBox
                                Grid.Row="1"
                                Grid.Column="2"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding Cassette1Balance, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Cassette 2  -->
                            <TextBlock
                                Grid.Row="2"
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource Cassette2Label}" />
                            <ComboBox
                                Grid.Row="2"
                                Grid.Column="1"
                                ItemsSource="{Binding CassetteDenominations}"
                                SelectedItem="{Binding Cassette2Denomination}"
                                Style="{StaticResource ComboBoxStyle}" />
                            <TextBox
                                Grid.Row="2"
                                Grid.Column="2"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding Cassette2Balance, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Cassette 3  -->
                            <TextBlock
                                Grid.Row="3"
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource Cassette3Label}" />
                            <ComboBox
                                Grid.Row="3"
                                Grid.Column="1"
                                ItemsSource="{Binding CassetteDenominations}"
                                SelectedItem="{Binding Cassette3Denomination}"
                                Style="{StaticResource ComboBoxStyle}" />
                            <TextBox
                                Grid.Row="3"
                                Grid.Column="2"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding Cassette3Balance, UpdateSourceTrigger=PropertyChanged}" />

                            <!--  Cassette 4  -->
                            <TextBlock
                                Grid.Row="4"
                                Grid.Column="0"
                                HorizontalAlignment="Center"
                                Style="{StaticResource LabelStyle}"
                                Text="{DynamicResource Cassette4Label}" />
                            <ComboBox
                                Grid.Row="4"
                                Grid.Column="1"
                                ItemsSource="{Binding CassetteDenominations}"
                                SelectedItem="{Binding Cassette4Denomination}"
                                Style="{StaticResource ComboBoxStyle}" />
                            <TextBox
                                Grid.Row="4"
                                Grid.Column="2"
                                Style="{StaticResource TextBoxStyle}"
                                Text="{Binding Cassette4Balance, UpdateSourceTrigger=PropertyChanged}" />
                        </Grid>
                    </GroupBox>

                    <!--  Notes  -->
                    <GroupBox Header="{DynamicResource NotesGroupHeader}" Style="{StaticResource GroupBoxStyle}">
                        <TextBox
                            Height="100"
                            AcceptsReturn="True"
                            Style="{StaticResource TextBoxStyle}"
                            Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                            TextWrapping="Wrap"
                            VerticalScrollBarVisibility="Auto" />
                    </GroupBox>
                </StackPanel>
            </Grid>
        </ScrollViewer>

        <!--  Action Buttons  -->
        <Border
            Grid.Row="2"
            Padding="20"
            Background="{StaticResource LightGrayBrush}"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Width="100"
                    Margin="0,0,10,0"
                    Command="{Binding CancelCommand}"
                    Content="{DynamicResource CancelButtonText}"
                    Style="{StaticResource SecondaryButtonStyle}" />
                <Button
                    Width="100"
                    Command="{Binding SaveCommand}"
                    Content="{Binding IsSaving, Converter={StaticResource BooleanToSavingTextConverter}}"
                    IsEnabled="{Binding IsSaving, Converter={StaticResource InverseBooleanConverter}}"
                    Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>