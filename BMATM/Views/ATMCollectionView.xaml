<UserControl
    x:Class="BMATM.Views.ATMCollectionView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="600"
    d:DesignWidth="800"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Grid
            Grid.Row="0"
            Margin="0,0,0,20"
            Background="{StaticResource PrimaryBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock
                Grid.Column="0"
                Margin="20,15"
                VerticalAlignment="Center"
                FontSize="24"
                FontWeight="Bold"
                Foreground="White"
                Text="{DynamicResource ATMCollectionTitle}" />

            <StackPanel
                Grid.Column="1"
                Margin="0,0,20,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Button
                    Width="100"
                    Margin="0,0,10,0"
                    Command="{Binding RefreshCommand}"
                    Content="{DynamicResource RefreshButtonText}"
                    Style="{StaticResource SecondaryButtonStyle}" />
                <Button
                    Width="120"
                    Command="{Binding AddATMCommand}"
                    Content="{DynamicResource AddATMButtonText}"
                    Style="{StaticResource PrimaryButtonStyle}" />
            </StackPanel>
        </Grid>

        <!--  Content  -->
        <Grid Grid.Row="1" Margin="20,0,20,20">
            <!--  Loading Indicator  -->
            <StackPanel
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Orientation="Vertical"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ProgressBar
                    Width="200"
                    Height="20"
                    Margin="0,0,0,20"
                    IsIndeterminate="True" />
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="16"
                    Text="{DynamicResource LoadingText}" />
            </StackPanel>

            <!--  ATM Collection  -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  ATM Cards ScrollViewer  -->
                <ScrollViewer
                    Grid.Row="0"
                    Margin="0,0,0,20"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding ATMs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    Width="300"
                                    Height="350"
                                    Margin="0,0,20,0"
                                    Background="White"
                                    BorderBrush="{StaticResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Effect="{StaticResource CardShadow}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <!--  ATM Image  -->
                                        <Image
                                            Grid.Row="0"
                                            Width="120"
                                            Height="120"
                                            Margin="20,20,20,10"
                                            HorizontalAlignment="Center"
                                            Source="{Binding ATMType, Converter={StaticResource ATMTypeToImageConverter}}"
                                            Stretch="Uniform" />

                                        <!--  ATM Info  -->
                                        <StackPanel Grid.Row="1" Margin="20,0,20,10">
                                            <TextBlock
                                                Margin="0,0,0,10"
                                                HorizontalAlignment="Center"
                                                FontSize="18"
                                                FontWeight="Bold"
                                                Text="{Binding ATMNumber}" />

                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="0"
                                                    Margin="0,2"
                                                    FontWeight="SemiBold"
                                                    Text="{DynamicResource ATMTypeLabel}" />
                                                <TextBlock
                                                    Grid.Row="0"
                                                    Grid.Column="1"
                                                    Margin="10,2,0,2"
                                                    Text="{Binding ATMType, Converter={StaticResource ATMTypeToDisplayNameConverter}}" />

                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="0"
                                                    Margin="0,2"
                                                    FontWeight="SemiBold"
                                                    Text="{DynamicResource BranchLabel}" />
                                                <TextBlock
                                                    Grid.Row="1"
                                                    Grid.Column="1"
                                                    Margin="10,2,0,2"
                                                    Text="{Binding BranchName}" />

                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="0"
                                                    Margin="0,2"
                                                    FontWeight="SemiBold"
                                                    Text="{DynamicResource LocationLabel}" />
                                                <TextBlock
                                                    Grid.Row="2"
                                                    Grid.Column="1"
                                                    Margin="10,2,0,2"
                                                    Text="{Binding Location}"
                                                    TextWrapping="Wrap" />

                                                <TextBlock
                                                    Grid.Row="3"
                                                    Grid.Column="0"
                                                    Margin="0,2"
                                                    FontWeight="SemiBold"
                                                    Text="{DynamicResource StatusLabel}" />
                                                <TextBlock
                                                    Grid.Row="3"
                                                    Grid.Column="1"
                                                    Margin="10,2,0,2"
                                                    Foreground="{Binding IsActive, Converter={StaticResource BooleanToStatusColorConverter}}"
                                                    Text="{Binding IsActive, Converter={StaticResource BooleanToStatusConverter}}" />
                                            </Grid>
                                        </StackPanel>

                                        <!--  Action Buttons  -->
                                        <StackPanel
                                            Grid.Row="2"
                                            Margin="20,0,20,20"
                                            HorizontalAlignment="Center"
                                            Orientation="Horizontal">
                                            <Button
                                                Width="80"
                                                Margin="0,0,10,0"
                                                Command="{Binding DataContext.EditATMCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{DynamicResource EditButtonText}"
                                                Style="{StaticResource SecondaryButtonStyle}" />
                                            <Button
                                                Width="80"
                                                Command="{Binding DataContext.DeleteATMCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Content="{DynamicResource DeleteButtonText}"
                                                Style="{StaticResource DangerButtonStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!--  Empty State  -->
                <StackPanel
                    Grid.Row="0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical"
                    Visibility="{Binding ATMs.Count, Mode=OneWay, Converter={StaticResource CountToVisibilityConverter}}">
                    <TextBlock
                        Margin="0,0,0,20"
                        HorizontalAlignment="Center"
                        FontSize="18"
                        Text="{DynamicResource NoATMsFoundText}" />
                    <Button
                        Width="150"
                        Command="{Binding AddATMCommand}"
                        Content="{DynamicResource AddFirstATMButtonText}"
                        Style="{StaticResource PrimaryButtonStyle}" />
                </StackPanel>

                <!--  Status Bar  -->
                <Border
                    Grid.Row="1"
                    Padding="20,10"
                    Background="{StaticResource LightGrayBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                    <TextBlock>
                        <Run Text="{DynamicResource TotalATMsText}" />
                        <Run FontWeight="Bold" Text="{Binding ATMs.Count, Mode=OneWay}" />
                    </TextBlock>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>