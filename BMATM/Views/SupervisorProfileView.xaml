<UserControl
    x:Class="BMATM.Views.SupervisorProfileView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Background="{DynamicResource BackgroundColor}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header  -->
        <Border
            Grid.Row="0"
            Padding="20"
            Background="{DynamicResource HeaderBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Style="{DynamicResource HeaderTextStyle}"
                    Text="{DynamicResource SupervisorProfile}" />

                <Button
                    Grid.Column="1"
                    Command="{Binding LogoutCommand}"
                    Content="{DynamicResource Close}"
                    Style="{DynamicResource SecondaryButtonStyle}" />
            </Grid>
        </Border>

        <!--  Content  -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <StackPanel MaxWidth="600">
                <!--  User Information Card  -->
                <Border
                    Margin="0,0,0,20"
                    Padding="20"
                    Background="White"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!--  Name  -->
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="0"
                            Margin="0,0,20,10"
                            Style="{DynamicResource LabelStyle}"
                            Text="{DynamicResource Name}" />
                        <TextBlock
                            Grid.Row="0"
                            Grid.Column="1"
                            Margin="0,0,0,10"
                            FontSize="14"
                            Text="{Binding CurrentUser.DisplayName}" />

                        <!--  Username  -->
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="0"
                            Margin="0,0,20,10"
                            Style="{DynamicResource LabelStyle}"
                            Text="{DynamicResource Username}" />
                        <TextBlock
                            Grid.Row="1"
                            Grid.Column="1"
                            Margin="0,0,0,10"
                            FontSize="14"
                            Text="{Binding CurrentUser.Username}" />

                        <!--  Branch Number  -->
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="0"
                            Margin="0,0,20,10"
                            Style="{DynamicResource LabelStyle}"
                            Text="{DynamicResource BranchNumber}" />
                        <TextBlock
                            Grid.Row="2"
                            Grid.Column="1"
                            Margin="0,0,0,10"
                            FontSize="14"
                            Text="{Binding CurrentUser.BranchCode}" />

                        <!--  Branch Name  -->
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="0"
                            Margin="0,0,20,0"
                            Style="{DynamicResource LabelStyle}"
                            Text="{DynamicResource BranchName}" />
                        <TextBlock
                            Grid.Row="3"
                            Grid.Column="1"
                            FontSize="14"
                            Text="{Binding CurrentUser.BranchName}" />
                    </Grid>
                </Border>

                <!--  ATM Management Section  -->
                <Border
                    Padding="20"
                    Background="White"
                    BorderBrush="{DynamicResource BorderColor}"
                    BorderThickness="1"
                    CornerRadius="8">
                    <StackPanel>
                        <TextBlock
                            Margin="0,0,0,20"
                            FontSize="18"
                            FontWeight="SemiBold"
                            Foreground="{DynamicResource PrimaryColor}"
                            Text="{DynamicResource ATMCollection}" />

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                Grid.Column="0"
                                VerticalAlignment="Center"
                                FontSize="14"
                                Text="{DynamicResource ATMCount}" />

                            <Button
                                Grid.Column="1"
                                Command="{Binding AddATMCommand}"
                                Content="{DynamicResource AddATM}"
                                Style="{DynamicResource PrimaryButtonStyle}" />
                        </Grid>

                        <!--  ATM List Placeholder  -->
                        <TextBlock
                            Margin="0,20,0,0"
                            FontStyle="Italic"
                            Foreground="Gray"
                            Text="No ATMs configured yet. Click 'Add ATM' to get started."
                            TextAlignment="Center" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>