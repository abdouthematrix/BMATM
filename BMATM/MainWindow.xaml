<Window
    x:Class="BMATM.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:BMATM.Views"
    Title="{DynamicResource AppTitle}"
    Width="800"
    Height="600"
    FlowDirection="{DynamicResource FlowDirection}"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  Header with Language Switcher  -->
        <Border
            Grid.Row="0"
            Padding="10"
            Background="{DynamicResource HeaderBackground}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    Style="{DynamicResource HeaderTextStyle}"
                    Text="{DynamicResource AppTitle}" />

                <StackPanel
                    Grid.Column="1"
                    Margin="10,0,0,0"
                    Orientation="Horizontal">
                    <Button
                        Margin="0,0,5,0"
                        Command="{Binding SwitchLanguageCommand}"
                        CommandParameter="ar"
                        Content="العربية"
                        Style="{DynamicResource LanguageButtonStyle}" />
                    <Button
                        Command="{Binding SwitchLanguageCommand}"
                        CommandParameter="en"
                        Content="English"
                        Style="{DynamicResource LanguageButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  Main Content Area  -->
        <ContentControl
            x:Name="MainContent"
            Grid.Row="1"
            Content="{Binding CurrentView}" />
    </Grid>
</Window>